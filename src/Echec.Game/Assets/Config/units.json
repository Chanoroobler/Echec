{
  // Paramétrage des classes par domaine.
  // Le motif de déplacement (Pion=8 dir, Fou=diagonales, Cavalier=saut, Tour=lignes, Dame=8 dir)
  // est fixé en code par le domaine. Ici on règle : nom, asset (PNG dans Assets/Units/<asset>.png),
  // PV (hp), dégâts (damage), portée de déplacement (moveRange) et portée de tir (attackRange).
  // "piercesAllies": true => la classe tire À TRAVERS ses alliés sans les toucher (les ennemis bloquent
  // toujours). Absent = false.
  "domaines": [
    {
      "domaine": "Pion",
      "baseClass": { "name": "Soldat", "asset": "soldat", "hp": 10, "damage": 4, "moveRange": 1, "attackRange": 1 }
    },
    {
      "domaine": "Fou",
      "baseClass": { "name": "Eclaireur", "asset": "eclaireur", "hp": 8, "damage": 4, "moveRange": 3, "attackRange": 2 }
    },
    {
      "domaine": "Cavalier",
      "baseClass": { "name": "Cavalier", "asset": "cavalier", "hp": 10, "damage": 5, "moveRange": 1, "attackRange": 1 }
    },
    {
      "domaine": "Tour",
      "baseClass": { "name": "Lancier", "asset": "lancier", "hp": 12, "damage": 4, "moveRange": 3, "attackRange": 2, "piercesAllies": true }
    },
    {
      "domaine": "Dame",
      "baseClass": { "name": "Archer", "asset": "archer", "hp": 8, "damage": 5, "moveRange": 2, "attackRange": 3 }
    }
  ],

  // Unités COMMANDE (meneurs). COMMANDE est un ROLE, pas un domaine : chaque meneur
  // emprunte le motif de deplacement d'un des 5 domaines (champ "domaine"), qui peut
  // varier d'un meneur a l'autre. role = "Commander" (joueur) ou "Boss" (ennemi).
  "commandes": [
    { "role": "Commander", "domaine": "Pion", "name": "Commandant", "asset": "commandant", "hp": 26, "damage": 6, "moveRange": 1, "attackRange": 1 },
    { "role": "Boss",      "domaine": "Pion", "name": "Boss",       "asset": "boss",       "hp": 30, "damage": 8, "moveRange": 1, "attackRange": 1 }
  ]
}
